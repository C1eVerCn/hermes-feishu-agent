# Agent behavior — defaults are safe, change only after reading CLAUDE.md
# AGENT_MAX_ITERATIONS=2 matches the system-prompt rule "单轮对话最多 2 次工具调用":
# 1 call returns the tool_call, 2nd call returns the final text. Don't raise
# unless the system-prompt budget is also raised.
AGENT_MAX_ITERATIONS=2
# AGENT_TIMEOUT_SECONDS=120 per CLAUDE.md hard limit. With AGENT_MAX_ITERATIONS=2
# and minimax M2.7-highspeed, the LLM needs ~30s end-to-end (1 tool + 1 summary
# = 2 API calls @ ~14s each). 30s here was hitting timeout and sending a
# misleading "响应超时" to the user while the LLM was still finishing.
AGENT_TIMEOUT_SECONDS=120
AGENT_POOL_MAX_SIZE=100

# Service
HTTP_PORT=8088
LOG_LEVEL=INFO

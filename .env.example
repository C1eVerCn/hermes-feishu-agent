# ── Feishu app credentials (required) — get from open.feishu.cn/app ──────────
FEISHU_APP_ID=cli_xxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxx
FEISHU_ENCRYPT_KEY=          # optional: only if message encryption is enabled
FEISHU_VERIFY_TOKEN=         # optional

# 飞书消息出队投递（后端 feishu_message_record → bot 拉取发送审批通知等）。
# 须与后端 nacos 的 feishu.bot.openApi.appKey 一致；留空则消息泵不启动（功能 inert）。
# 前置：dmz-fmp-mcp 需重新部署（含 pull_pending_feishu_message / report_feishu_message_result）。
FEISHU_BOT_APP_KEY=          # optional: 配了才启用飞书消息出队投递
# FEISHU_MSG_POLL_INTERVAL=30   # 轮询间隔秒（默认 30）
# FEISHU_MSG_POLL_LIMIT=50      # 每轮最多拉取条数（默认 50，上游上限 200）

# ── Minimax API (MINIMAX_API_KEY required) ───────────────────────────────────
MINIMAX_API_KEY=xxxxxxxxxx
MINIMAX_BASE_URL=https://api.minimax.chat/v1
MINIMAX_MODEL=MiniMax-Text-01
# api_mode：M3/anthropic 兼容端点用 anthropic_messages 才能 tool_use；OpenAI chat_completions 模式 M3 不识别 tools
MINIMAX_API_MODE=anthropic_messages

# ── Agent behavior — defaults are safe, change only after reading CLAUDE.md ──
# AGENT_MAX_ITERATIONS=30 and AGENT_TIMEOUT_SECONDS=120 are hard limits per
# CLAUDE.md — do not lower without discussion (multi-tool turns get truncated).
AGENT_MAX_ITERATIONS=30
AGENT_TIMEOUT_SECONDS=120
AGENT_POOL_MAX_SIZE=100

# ── Service ──────────────────────────────────────────────────────────────────
HTTP_PORT=8088
LOG_LEVEL=INFO

# ── Business backends (single domain) ─────────────────────────────────────────
# Vehicle reservation (车辆预约) — FastMCP stdio server，对齐参考项目
# reservation_agent-test-agent_multigraph。bot spawn Python 子进程
# (car_tools.booking_mcp_server.py)，9 个 @mcp.tool() 通过 httpx 调上游。
# 上游 fmp 后端 URL 传给 server 子进程（CAR_API_BASE_URL / CAR_API_PREFIX）。
CAR_MCP_SERVER_NAME=car_booking

# ── OCL — Output Control Layer ───────────────────────────────────────────────
# Feishu open_id of admin users, comma-separated. Admins can run
# `设置角色 <open_id> <1|2|3>` and `查看用户` in Feishu chat.
OCL_ADMIN_USER_IDS=ou_xxxxxxxxxx
# Hard truncation limit for LLM responses (chars)
OCL_MAX_OUTPUT_CHARS=4000
OCL_WARN_OUTPUT_CHARS=2000
# Message shown when content is blocked
OCL_CONTENT_BLOCK_MESSAGE=抱歉，该内容不在我的服务范围内，请换一个问题。

# ── Identity & self-evolution memory ─────────────────────────────────────────
# open_id → role overrides live in data/identity_map.json (gitignored; copy
# from data/identity_map.json.example). email/name are auto-resolved via the
# Feishu Contact API — the file only stores admin role overrides.
#
# Cross-session memory store root (default: ./data). Persisted across restarts.
# DMZ_MEMORY_HOME=/path/to/persistent/data
